# =========================
# Backend (Python / FastAPI)
# =========================
# کش‌های پایتون
__pycache__/
*.py[cod]
*$py.class

# محیط‌های مجازی (اگر ساختی)
venv/
env/
.venv/
venv_economy/

# فایل‌های حساس و کلیدها
backend/.env
.env

# =========================
# Frontend (Next.js / Node.js)
# =========================
# پوشه سنگین پکیج‌ها
frontend/node_modules/
node_modules/

# پوشه‌های بیلد و خروجی نکست‌جی‌اس
frontend/.next/
.next/
out/
build/

# فایل‌های حساس فرانت‌اند
frontend/.env.local
.env.local
.env.development.local
.env.test.local
.env.production.local

# لاگ‌های خطا
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================
# OS & Editor Files
# =========================
# فایل‌های سیستمی و تنظیمات ادیتور
.DS_Store
.vscode/
.idea/
*.log